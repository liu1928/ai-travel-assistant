# === Anthropic ===
ANTHROPIC_API_KEY=
# 可選：行程生成模型（預設 claude-sonnet-4-6）
ANTHROPIC_MODEL=
# 可選：標籤模型（預設 claude-haiku-4-5-20251001，最省）
ANTHROPIC_TAGGING_MODEL=

# === Google Maps Platform ===
# Places API (New) 金鑰；需在 GCP 啟用 Places API 並綁定帳單帳號
GOOGLE_MAPS_API_KEY=

# === Firebase (Admin SDK / service account) ===
# Firebase 主控台 → 專案設定 → 服務帳戶 → 產生新的私密金鑰
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 整段貼上（含 BEGIN/END）；換行用 \n 表示，程式會自動還原
FIREBASE_PRIVATE_KEY=

# === 用量護欄（每日成本上限，美金；留空用程式預設）===
# 使用者每日預估花費上限（預設 2）；超過該入口回 429
QUOTA_USER_DAILY_USD=
# 全域每日預估花費上限（預設 10）；超過所有付費入口回 503 熔斷
QUOTA_GLOBAL_DAILY_USD=

# === 住宿訂房連結變現（擇一填；不填則產純 Booking 連結、無佣金）===
# 推薦 Stay22（聚合多 OTA、承接 Booking 合作變動、全球可用）
NEXT_PUBLIC_STAY22_AID=
# Booking 原生 affiliate id（若有直接 affiliate）
NEXT_PUBLIC_BOOKING_AID=
# Travelpayouts marker（若走 Travelpayouts）
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=

# === 分帳 App (split-bill) ===
# 分帳 app 部署後的網址（不含結尾斜線）；留空則行程頁不顯示「去分帳」連結
NEXT_PUBLIC_SPLIT_BILL_URL=

# === Gemini（開發流程用，非 app 功能）===
# scripts/gemini-review.mjs（CLAUDE.md 步驟 4 的 code review）用的 API key
GEMINI_API_KEY=
