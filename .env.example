# === Anthropic ===
ANTHROPIC_API_KEY=
# 可選：行程生成模型（預設 claude-sonnet-4-6）
ANTHROPIC_MODEL=
# 可選：標籤模型（預設 claude-haiku-4-5-20251001，最省）
ANTHROPIC_TAGGING_MODEL=

# === Google Maps Platform ===
# Places API (New) 金鑰；需在 GCP 啟用 Places API 並綁定帳單帳號
GOOGLE_MAPS_API_KEY=

# === Firebase (Admin SDK / service account) ===
# Firebase 主控台 → 專案設定 → 服務帳戶 → 產生新的私密金鑰
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 整段貼上（含 BEGIN/END）；換行用 \n 表示，程式會自動還原
FIREBASE_PRIVATE_KEY=

# === 分帳 App (split-bill) ===
# 分帳 app 部署後的網址（不含結尾斜線）；留空則行程頁不顯示「去分帳」連結
NEXT_PUBLIC_SPLIT_BILL_URL=
